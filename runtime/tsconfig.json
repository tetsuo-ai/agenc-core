{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2023"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "bun:bundle": ["./src/build/feature.ts"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    // Imports the live TUI renderer, which is excluded from the baseline
    // tsc gate until replacement is complete. This shipped prompt is still
    // covered by the required tsup DTS build because tsup.config.ts lists it
    // as a production entrypoint.
    "src/bin/tui-trust-prompt.tsx",
    "src/memdir/**/*",
    "src/services/SessionMemory/**/*",
    "src/components/FeedbackSurvey/**/*",
    "src/components/MemoryUsageIndicator.tsx",
    "src/components/memory/**/*",
    "src/components/messages/UserMemoryInputMessage.tsx",
    "src/commands/memory/memory.tsx",
    "src/tools/AgentTool/agentMemory.ts",
    "src/tools/AgentTool/agentMemorySnapshot.ts",
    "src/tools/AskUserQuestionTool/AskUserQuestionTool.tsx",
    "src/tools/ask-user-question/tui-tool.tsx",
    // Z-PURGEC moved donor-origin surfaces out of the mirror. Keep them out of
    // the baseline typecheck until each subsystem is made strict-owned.
    "src/agents/**/*",
    "src/auth/**/*",
    "src/bin/agenc.ts",
    "src/bin/mcp-cli.ts",
    "src/bootstrap/**/*",
    "src/bridge/**/*",
    "src/cli/**/*",
    "src/commands/**/*",
    "src/commands.ts",
    "src/config/**/*",
    "src/context.ts",
    "src/coordinator/**/*",
    "src/cost/**/*",
    "src/elicitation/**/*",
    "src/entrypoints/**/*",
    "src/errors/**/*",
    "src/grpc/**/*",
    "src/llm/**/*",
    "src/migrations/**/*",
    "src/native-ts/**/*",
    "src/outputStyles/**/*",
    "src/plugins/**/*",
    "src/proto/**/*",
    "src/query/**/*",
    "src/query.ts",
    "src/relay-proxy/**/*",
    "src/remote/**/*",
    "src/schemas/**/*",
    "src/screens/**/*",
    "src/server/**/*",
    "src/services/**/*",
    "src/session/**/*",
    "src/setup.ts",
    "src/skills/**/*",
    "src/state/**/*",
    "src/tasks/**/*",
    "src/tasks.ts",
    "src/tools/**/*",
    "src/tools.ts",
    "src/constants/**/*",
    "src/utils/**/*",
    "src/utils/attachments.ts",
    "src/utils/memoryFileDetection.ts",
    "src/utils/teamMemoryOps.ts",
    "src/utils/memory/**/*",
    "src/agenc/**/*",
    "src/tui/**/*"
  ]
}
