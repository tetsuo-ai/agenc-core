{
  "name": "@tetsuo-ai/runtime",
  "version": "0.2.0",
  "private": true,
  "description": "AgenC lean coding CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc": "bin/agenc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/write-build-version.mjs && npm run check:package-entrypoints",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tui.json",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:runtime-ownership": "node scripts/check-runtime-ownership.mjs",
    "check:executor-baseline": "node scripts/check-executor-baseline.mjs",
    "test": "vitest run",
    "validate:required": "npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenc",
    "coding",
    "cli",
    "grok"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "cheerio": "^1.2.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "quickjs-emscripten": "^0.32.0"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "0.3.0",
    "@anthropic-ai/sdk": "^0.81.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "auto-bind": "^5.0.1",
    "axios": "1.15.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "emoji-regex": "^10.6.0",
    "eventsource": "^2.0.2",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "jimp": "^1.6.1",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "^0.33.0",
    "signal-exit": "^4.1.0",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "undici": "^7.22.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.4.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
