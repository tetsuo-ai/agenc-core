{
  "name": "@tetsuo-ai/runtime",
  "version": "0.2.0",
  "private": true,
  "description": "Agent runtime infrastructure for AgenC coordination on Solana",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc-runtime": "dist/bin/agenc-runtime.js",
    "agenc": "dist/bin/agenc.js",
    "agenc-watch": "dist/bin/agenc-watch.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.js"
    },
    "./operator-events": {
      "types": "./dist/operator-events.d.ts",
      "import": "./dist/operator-events.mjs",
      "require": "./dist/operator-events.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "npm run build --workspace=@tetsuo-ai/desktop-tool-contracts",
    "build": "tsup --config tsup.config.ts && node scripts/build-dashboard-assets.mjs && node scripts/write-build-version.mjs && npm run check:package-entrypoints",
    "pretypecheck": "npm run build --workspace=@tetsuo-ai/desktop-tool-contracts",
    "typecheck": "tsc --noEmit",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:executor-baseline": "node scripts/check-executor-baseline.mjs",
    "check-idl-drift": "tsx scripts/check-idl-drift.ts",
    "pretest": "npm run build --workspace=@tetsuo-ai/desktop-tool-contracts && npm run build --workspace=@tetsuo-ai/plugin-kit-channel-fixture",
    "test": "vitest run",
    "validate:required": "npx tsx scripts/run-required-validation.ts",
    "test:marketplace-integration": "vitest run tests/marketplace-cli.integration.test.ts",
    "test:cross-repo-integration": "vitest run tests/integration.test.ts tests/eval-replay.integration.test.ts tests/benchmark-runner.integration.test.ts tests/marketplace-cli.integration.test.ts",
    "test:watch-node": "node --test tests/watch/*.test.mjs",
    "test:watch": "vitest",
    "repro:pipeline:http": "npx tsx scripts/repro-pipeline-http.ts",
    "benchmark": "npx tsx scripts/run-benchmarks.ts",
    "benchmark:ci": "npx tsx scripts/run-benchmarks.ts --output benchmarks/artifacts/ci.json",
    "benchmark:pipeline": "npx tsx scripts/run-pipeline-quality.ts",
    "benchmark:pipeline:ci": "npx tsx scripts/run-pipeline-quality.ts --output benchmarks/artifacts/pipeline-quality.ci.json",
    "benchmark:pipeline:gates": "npx tsx scripts/check-pipeline-gates.ts --artifact benchmarks/artifacts/pipeline-quality.ci.json",
    "benchmark:background-runs": "npx tsx scripts/run-background-run-quality.ts",
    "benchmark:background-runs:ci": "npx tsx scripts/run-background-run-quality.ts --output benchmarks/artifacts/background-run-quality.ci.json",
    "benchmark:background-runs:gates": "npx tsx scripts/check-background-run-gates.ts",
    "shell:rollout:ci": "npx tsx scripts/run-shell-rollout-readiness.ts --output benchmarks/artifacts/shell-rollout-readiness.ci.json",
    "autonomy:rollout:gates": "npx tsx scripts/check-autonomy-rollout-gates.ts --mode limited --config benchmarks/autonomy-gateway.ci.json --artifact benchmarks/artifacts/background-run-quality.ci.json --delegation-artifact benchmarks/artifacts/delegation-quality.ci.json --shell-artifact benchmarks/artifacts/shell-rollout-readiness.ci.json --manifest ../docs/autonomy-runtime-rollout.manifest.json",
    "benchmark:delegation": "npx tsx scripts/run-delegation-benchmarks.ts --output benchmarks/artifacts/delegation-benchmark.latest.json",
    "benchmark:delegation:ci": "npx tsx scripts/run-pipeline-quality.ts --output benchmarks/artifacts/delegation-quality.ci.json --desktop-runs 0 --delegation-k 2",
    "benchmark:delegation:gates": "npx tsx scripts/check-pipeline-gates.ts --artifact benchmarks/artifacts/delegation-quality.ci.json",
    "benchmark:decomposition-search": "npx tsx scripts/run-decomposition-search.ts --output benchmarks/artifacts/decomposition-search.latest.json",
    "mutation": "npx tsx scripts/run-mutations.ts",
    "mutation:ci": "npx tsx scripts/run-mutations.ts --output benchmarks/artifacts/mutation.ci.json --trend-output benchmarks/artifacts/mutation-trend.ci.json",
    "mutation:gates": "npx tsx scripts/check-mutation-gates.ts --artifact benchmarks/artifacts/mutation.ci.json --policy benchmarks/mutation-gating-policy.ci.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "agents",
    "runtime",
    "coordination",
    "privacy",
    "zk"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "discord.js": "^14.25.1",
    "edge-tts": "^1.0.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.0",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "bn.js": "^5.2.3",
    "express-rate-limit": "^8.3.1",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "resolutions": {
    "@hono/node-server": "^1.19.11",
    "bn.js": "^5.2.3",
    "express-rate-limit": "^8.3.1",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tetsuo-ai/desktop-tool-contracts": "0.1.0",
    "@tetsuo-ai/plugin-kit": "0.2.0",
    "@tetsuo-ai/protocol": "0.2.0",
    "@tetsuo-ai/sdk": "1.4.0",
    "bn.js": "^5.2.3",
    "jimp": "^1.6.1",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "@tetsuo-ai/plugin-kit-channel-fixture": "0.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "anchor-litesvm": "^0.2.1",
    "bs58": "^6.0.0",
    "litesvm": "^0.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "agenc": {
    "bundledExternalPlugins": [
      {
        "name": "@tetsuo-ai/plugin-concordia",
        "siblingRepoPath": "../agenc-plugin-concordia"
      }
    ]
  }
}
