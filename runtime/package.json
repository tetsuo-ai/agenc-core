{
  "name": "@tetsuo-ai/runtime",
  "version": "0.2.0",
  "private": true,
  "description": "AgenC lean coding CLI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc": "dist/bin/agenc.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/write-build-version.mjs && npm run check:package-entrypoints",
    "typecheck": "tsc --noEmit",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:executor-baseline": "node scripts/check-executor-baseline.mjs",
    "test": "vitest run",
    "validate:required": "npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenc",
    "coding",
    "cli",
    "grok"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "cheerio": "^1.2.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "jimp": "^1.6.1",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
