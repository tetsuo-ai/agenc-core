{
  "name": "@tetsuo-ai/runtime",
  "version": "0.2.0",
  "private": true,
  "description": "AgenC lean coding CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc": "bin/agenc",
    "agenc-linux-sandbox": "bin/agenc-linux-sandbox"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/write-build-version.mjs && npm run check:package-entrypoints",
    "daemon": "node bin/agenc daemon start --foreground",
    "daemon:status": "node bin/agenc daemon status",
    "start": "node bin/agenc",
    "typecheck": "tsc --noEmit",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:runtime-ownership": "node scripts/check-runtime-ownership.mjs",
    "check:executor-baseline": "node scripts/check-executor-baseline.mjs",
    "check:tui-runtime-startup": "node scripts/check-tui-runtime-startup.mjs",
    "compile:react": "node scripts/compile-react.mjs",
    "check:tui-e2e": "node scripts/check-tui-e2e/runner.mjs",
    "check:llm-pipeline": "node scripts/check-llm-pipeline/runner.mjs",
    "check:daemon-errors": "node scripts/check-daemon-errors/runner.mjs",
    "check:e2e-all": "npm run check:daemon-errors && npm run check:llm-pipeline && npm run check:tui-e2e",
    "test": "vitest run",
    "validate:required": "npm run typecheck && npm run test && npm run check:tui-runtime-startup && npm run check:e2e-all",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenc",
    "coding",
    "cli",
    "grok"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "cheerio": "^1.2.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "quickjs-emscripten": "^0.32.0"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "0.3.0",
    "@ant/computer-use-mcp": "file:local-packages/computer-use-mcp",
    "@anthropic-ai/sandbox-runtime": "0.0.46",
    "@anthropic-ai/sdk": "^0.81.0",
    "@growthbook/growthbook": "1.6.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.6.1",
    "@opentelemetry/resources": "2.6.1",
    "@opentelemetry/sdk-logs": "0.214.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "ajv": "^8.20.0",
    "auto-bind": "^5.0.1",
    "axios": "1.15.0",
    "better-sqlite3": "^12.9.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "emoji-regex": "^10.6.0",
    "env-paths": "3.0.0",
    "execa": "9.6.1",
    "figures": "6.1.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.5.0",
    "https-proxy-agent": "7.0.6",
    "ignore": "7.0.5",
    "indent-string": "^5.0.0",
    "jimp": "^1.6.1",
    "js-yaml": "^4.1.0",
    "jsonc-parser": "3.3.1",
    "lodash-es": "^4.17.21",
    "lru-cache": "11.2.7",
    "markdown-it": "^14.1.1",
    "marked": "^15.0.12",
    "p-map": "7.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "^0.33.0",
    "shell-quote": "1.8.3",
    "signal-exit": "^4.1.0",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "turndown": "^7.2.4",
    "undici": "^7.22.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "8.2.0",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.18.0",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.4.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "tsup": "^8.5.1",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
