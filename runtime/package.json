{
  "name": "@tetsuo-ai/runtime",
  "version": "0.2.0",
  "private": true,
  "description": "AgenC lean coding CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agenc": "bin/agenc",
    "agenc-linux-sandbox": "bin/agenc-linux-sandbox"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/write-build-version.mjs && npm run check:package-entrypoints",
    "typecheck": "tsc --noEmit",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "check:runtime-ownership": "node scripts/check-runtime-ownership.mjs",
    "check:executor-baseline": "node scripts/check-executor-baseline.mjs",
    "check:codex-control-parity": "node ../scripts/check-codex-control-parity.mjs",
    "check:codex-registry-parity": "node ../scripts/check-codex-registry-parity.mjs",
    "check:codex-mailbox-parity": "node ../scripts/check-codex-mailbox-parity.mjs",
    "check:codex-status-parity": "node ../scripts/check-codex-status-parity.mjs",
    "check:codex-role-parity": "node ../scripts/check-codex-role-parity.mjs",
    "check:codex-thread-manager-parity": "node ../scripts/check-codex-thread-manager-parity.mjs",
    "check:codex-fork-context-parity": "node ../scripts/check-codex-fork-context-parity.mjs",
    "check:codex-thread-parity": "node ../scripts/check-codex-thread-parity.mjs",
    "check:codex-run-agent-parity": "node ../scripts/check-codex-run-agent-parity.mjs",
    "check:codex-agents-parity": "npm run check:codex-control-parity && npm run check:codex-registry-parity && npm run check:codex-mailbox-parity && npm run check:codex-status-parity && npm run check:codex-role-parity && npm run check:codex-thread-manager-parity && npm run check:codex-fork-context-parity && npm run check:codex-thread-parity && npm run check:codex-run-agent-parity",
    "check:codex-v2-agent-contract": "node ../scripts/verify-codex-v2-agent-contract.mjs",
    "test:codex-v2-agent-contract": "vitest run src/agents src/tasks src/bin/model-facing-tools.test.ts",
    "validate:codex-v2-agent-contract": "npm run check:codex-v2-agent-contract && npm run check:codex-agents-parity && npm run test:codex-v2-agent-contract",
    "check:openclaude-tui-replacement": "node scripts/check-openclaude-tui-replacement.mjs",
    "check:tui-runtime-startup": "node scripts/check-tui-runtime-startup.mjs",
    "test:openclaude-tui-replacement": "vitest run src/tui/openclaude/message-adapter.test.ts",
    "validate:openclaude-tui-replacement": "npm run check:openclaude-tui-replacement && npm run test:openclaude-tui-replacement && npm run build",
    "check:tui-openclaude-core-parity": "npm run check:openclaude-tui-replacement",
    "check:openclaude-tui-renderer-parity": "npm run check:openclaude-tui-replacement",
    "test:tui-openclaude-core-parity": "npm run test:openclaude-tui-replacement",
    "validate:tui-openclaude-core-parity": "npm run validate:openclaude-tui-replacement",
    "check:openclaude-footer-live-parity": "npm run check:openclaude-tui-replacement",
    "test:openclaude-footer-live-parity": "npm run test:openclaude-tui-replacement",
    "validate:openclaude-footer-live-parity": "npm run validate:openclaude-tui-replacement",
    "test:tui-yolo-openclaude-parity": "vitest run src/bin/agenc.tui-yolo-openclaude-parity.test.ts src/session/DiagnosticsSurface.openclaude-parity.test.ts src/tui/openclaude/message-adapter.test.ts",
    "test:agenc-memory-parity": "vitest run src/memdir/memory.contract.test.ts src/services/SessionMemory/session-memory.contract.test.ts src/commands/memory/memory.contract.test.tsx src/components/memory/memory-components.contract.test.tsx src/tools/AgentTool/agent-memory.contract.test.ts src/utils/memory/memory-utils.contract.test.ts src/utils/attachments-memory.contract.test.ts src/memory-wiring.contract.test.ts",
    "test": "vitest run",
    "validate:required": "npm run validate:codex-v2-agent-contract && npm run typecheck && npm run test && npm run check:openclaude-tui-replacement",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agenc",
    "coding",
    "cli",
    "grok"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "runtime"
  },
  "optionalDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "cheerio": "^1.2.0",
    "ollama": "^0.6.3",
    "openai": "^6.27.0",
    "quickjs-emscripten": "^0.32.0"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "0.3.0",
    "@ant/computer-use-mcp": "file:local-packages/computer-use-mcp",
    "@anthropic-ai/sandbox-runtime": "0.0.46",
    "@anthropic-ai/sdk": "^0.81.0",
    "@growthbook/growthbook": "1.6.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/core": "2.6.1",
    "@opentelemetry/resources": "2.6.1",
    "@opentelemetry/sdk-logs": "0.214.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@types/better-sqlite3": "^7.6.13",
    "ajv": "^8.20.0",
    "auto-bind": "^5.0.1",
    "axios": "1.15.0",
    "better-sqlite3": "^12.9.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "emoji-regex": "^10.6.0",
    "env-paths": "3.0.0",
    "eventsource": "^2.0.2",
    "figures": "6.1.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.5.0",
    "https-proxy-agent": "7.0.6",
    "ignore": "7.0.5",
    "indent-string": "^5.0.0",
    "jimp": "^1.6.1",
    "js-yaml": "^4.1.0",
    "jsonc-parser": "3.3.1",
    "lodash-es": "^4.17.21",
    "lru-cache": "11.2.7",
    "markdown-it": "^14.1.1",
    "marked": "^15.0.12",
    "p-map": "7.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "^0.33.0",
    "shell-quote": "1.8.3",
    "signal-exit": "^4.1.0",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "turndown": "^7.2.4",
    "undici": "^7.22.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "8.2.0",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.18.0",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.4.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
