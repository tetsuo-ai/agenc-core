{
  "name": "@tetsuo-ai/docs-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server serving AgenC documentation, contract artifacts, and runtime-scoped helper context to AI agents",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "agenc-docs": "./dist/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "architecture",
    "agents"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "docs-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "express-rate-limit": "^8.3.1",
    "hono": "^4.12.6"
  },
  "resolutions": {
    "express-rate-limit": "^8.3.1",
    "hono": "^4.12.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
