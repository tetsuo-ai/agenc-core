#!/usr/bin/env bash
# agenc-core pre-merge-commit hook.
#
# Fires when git is about to create a merge commit. Used by the goal
# harness to ensure that goal-driven merges only happen via
# scripts/goal/complete.mjs (which created a marker file just before
# invoking the merge).
#
# Behavior:
#   - If the merge source branch is "port/<id>", require that
#     .goal-completed/<id>.json exists. If not, block.
#   - For any other branch (manual local merges), allow.
#
# This stops the goal-runner (or anyone) from skipping verify.mjs and
# merging a port branch directly.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Read MERGE_MSG to detect which branch is being merged.
MSG_FILE="$REPO_ROOT/.git/MERGE_MSG"
if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

# Match e.g. "Merge branch 'port/F-01'"
SRC_BRANCH=$(sed -nE "s/^Merge branch '([^']+)'.*/\\1/p" "$MSG_FILE" | head -n1)
if [ -z "$SRC_BRANCH" ]; then
  exit 0
fi

case "$SRC_BRANCH" in
  port/*)
    ITEM_ID="${SRC_BRANCH#port/}"
    MARKER="$REPO_ROOT/.goal-completed/$ITEM_ID.json"
    if [ ! -f "$MARKER" ]; then
      echo >&2 "✗ refusing merge of $SRC_BRANCH: marker $MARKER not found."
      echo >&2 "  Goal-driven merges must go through: node scripts/goal/complete.mjs $ITEM_ID"
      exit 1
    fi
    ;;
esac

exit 0
