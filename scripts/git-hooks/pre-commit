#!/usr/bin/env bash
# agenc-core pre-commit hook.
#
# Runs the fast gates that must pass before any commit lands:
#   1. _deps/ real-vs-stub audit on staged runtime files
#   2. AgenC branding scan on staged files
#
# Skip via: git commit --no-verify (only when you really mean it,
# and never when running through the goal harness).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- gate 1: _deps real-vs-stub audit ------------------------------------

STAGED_RUNTIME=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^runtime/src/.*\.(ts|tsx|mts|cts)$' || true)
if [ -n "$STAGED_RUNTIME" ]; then
  node runtime/scripts/check-deps-stubs.mjs --staged
fi

# --- gate 2: branding scan -----------------------------------------------

# Scan staged source-shaped files for forbidden upstream brand identifiers.
# The scan understands per-line and per-file allow patterns for real
# external identifiers (provider model IDs, env vars, package names) and
# an inline override comment.
node scripts/branding-scan.mjs --staged
