{
  "name": "agenc-core",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "runtime",
    "test-fixtures/plugin-kit-channel-adapter"
  ],
  "scripts": {
    "build": "npm run build --workspace=@tetsuo-ai/runtime",
    "check:contract:agenc-compaction-context": "node runtime/scripts/check-agenc-compaction-context-contract.mjs",
    "test:contract:agenc-compaction-context": "node runtime/scripts/run-agenc-compaction-context-contract-tests.mjs",
    "validate:contract:agenc-compaction-context": "npm run check:contract:agenc-compaction-context && npm run test:contract:agenc-compaction-context",
    "validate:runtime": "npm run validate:required --workspace=@tetsuo-ai/runtime",
    "test": "npm run validate:runtime",
    "typecheck": "npm run typecheck --workspace=@tetsuo-ai/runtime"
  },
  "overrides": {
    "rollup": "^4.59.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "tsx": "^4.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
