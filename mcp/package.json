{
  "name": "@tetsuo-ai/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Model Context Protocol server for AgenC development — exposes protocol operations as MCP tools",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "agenc-mcp": "./dist/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "npm run build --workspace=@tetsuo-ai/runtime",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "mcp",
    "model-context-protocol",
    "agents",
    "coordination",
    "privacy",
    "zk",
    "developer-tools"
  ],
  "author": "Tetsuo AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tetsuo-ai/agenc-core",
    "directory": "mcp"
  },
  "dependencies": {
    "@tetsuo-ai/runtime": "0.2.0",
    "@tetsuo-ai/sdk": "1.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "express-rate-limit": "^8.3.1",
    "hono": "^4.12.6",
    "minimatch": "^9.0.9",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "resolutions": {
    "ajv": "^8.18.0",
    "express-rate-limit": "^8.3.1",
    "hono": "^4.12.6",
    "minimatch": "^9.0.9",
    "matrix-js-sdk": "^41.1.0-rc.0",
    "rollup": "^4.59.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@coral-xyz/anchor": ">=0.29.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "peerDependenciesMeta": {
    "@coral-xyz/anchor": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
