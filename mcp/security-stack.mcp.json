{
  "mcpServers": {
    "semgrep": {
      "command": "uvx",
      "args": ["semgrep-mcp", "--transport", "stdio"],
      "timeout": 30000
    },
    "trivy": {
      "command": "trivy",
      "args": ["mcp", "--transport", "stdio"],
      "timeout": 30000
    },
    "gitguardian": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/GitGuardian/ggmcp",
        "developer-mcp-server"
      ],
      "timeout": 30000
    },
    "solana-fender": {
      "command": "anchor-mcp",
      "args": ["--mcp"],
      "timeout": 30000
    }
  }
}
